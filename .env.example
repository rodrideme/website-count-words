# Google OAuth client (Google Cloud Console -> APIs & Services -> Credentials)
# Authorized redirect URI must be: http://localhost:8000/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Random secret used to sign the session cookie.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

# Sane defaults / caps for crawl size
DEFAULT_MAX_PAGES=150
MAX_PAGES_HARD_CAP=500
