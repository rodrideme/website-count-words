# Google OAuth client (Google Cloud Console -> APIs & Services -> Credentials)
# Authorized redirect URI must be: http://localhost:8000/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Random secret used to sign the session cookie.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

# Mailgun (https://mailgun.com) — sends an email when a crawl finishes,
# fails, or is stopped. Leave blank to disable email notifications entirely.
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
# Optional: defaults to "Word Counter <noreply@MAILGUN_DOMAIN>"
MAILGUN_FROM=
# Used to build the "view report" link in notification emails.
PUBLIC_BASE_URL=http://localhost:8000
